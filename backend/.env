# ── Copy this file to .env and fill in your values ────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://neondb_owner:npg_l4W2ZOgbdLRG@ep-small-union-aoqkcqgv.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT secret — use a long random string in production
# Generate one: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=change-me-in-production

# JWT settings (defaults are fine for dev)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Fixed admin credentials (change after initial setup)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@odoo.com
ADMIN_PASSWORD=admin@odoo.com

# Email validation
ALLOWED_EMAIL_DOMAIN=odoo.com
MIN_EMAIL_LOCAL_LENGTH=3

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=["http://localhost:3000"]

# Environment: development | production
APP_ENV=development
